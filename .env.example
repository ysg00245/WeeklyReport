# ── 주간보고 시스템 환경변수 템플릿 ──
# 이 파일을 .env 로 복사한 뒤 실제 값을 채우세요. (.env 는 절대 커밋 금지 — .gitignore 처리됨)
#   copy .env.example .env   (Windows)   /   cp .env.example .env   (macOS·Linux)

# 팀/시스템 관리자 비밀번호
ADMIN_PW=
# 시스템 관리자 비밀번호 (전사 최상위 권한 — 시스템 관리자 콘솔 접근)
SYSTEM_ADMIN_PW=

# Anthropic API 키 (AI 요약 기능용). 미사용 시 비워둬도 됨. 모델은 claude-sonnet-4-6 고정.
ANTHROPIC_API_KEY=

# 로컬 SQLite DB 경로 (기본값: weekly_report.db). DATABASE_URL 설정 시 무시됨.
DB_PATH=weekly_report.db

# PostgreSQL 연결 URL (Neon). 설정하면 SQLite 대신 Postgres 사용.
#   -pooler 포함 URL 자동 감지 → statement_cache_size=0 + pool_pre_ping 적용.
DATABASE_URL=

# Web Push VAPID sub (JWT 발급자). Apple Push 는 .local TLD 거부 →
#   https:// URL 또는 실제 운영 mailto: 권장. dev/운영 동일 값 사용.
VAPID_SUB=
